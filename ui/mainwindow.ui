  <property name="styleSheet">
   <string notr="true">/* Configuración del Fondo Principal */
QMainWindow {
    background-color: #1e1e24; /* Un tono oscuro más profundo y moderno */
}

/* Diseño de los Paneles Laterales y de Gráficos */
QWidget#panelIzquierdo, QGraphicsView {
    background-color: #2a2a35;
    border: 1px solid #3f3f50;
    border-radius: 8px; /* Bordes suavemente redondeados */
}

/* Estilo para los selectores de números y dropdowns */
QSpinBox, QComboBox {
    background-color: #333344;
    color: #ffffff;
    border: 1px solid #4f4f66;
    border-radius: 4px;
    padding: 5px;
    font-size: 12px;
}
QSpinBox:focus, QComboBox:focus {
    border: 1px solid #00b4d8; /* Brillo azul cuando los seleccionas */
}

/* Etiquetas de texto */
QLabel {
    color: #e2e2e2;
    font-weight: bold;
    font-size: 11px;
}

/* Botón Importar (Estilo Secundario - Elegante) */
QPushButton#btnImportar {
    background-color: #4a5568;
    color: #ffffff;
    border-radius: 6px;
    padding: 8px;
    font-weight: bold;
}
QPushButton#btnImportar:hover {
    background-color: #718096; /* Cambio de tono al pasar el mouse */
}

/* Botón Ejecutar (Estilo Primario - Llamativo) */
QPushButton#btnEjecutar {
    background-color: #00b4d8; /* Azul cyan eléctrico, resalta mucho más */
    color: #ffffff;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
    text-transform: uppercase;
}
QPushButton#btnEjecutar:hover {
    background-color: #0096c7;
}

</string>
